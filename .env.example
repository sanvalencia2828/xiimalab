# ═══════════════════════════════════════════════════════════════════════════════
# Xiimalab — Complete Environment Variables Template
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in required values (marked 🔴 REQUIRED)
# 3. NEVER commit .env to git
# 4. Run validation: scripts/validate-env.sh
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# 🔴 DATABASE — PostgreSQL Configuration
# ─────────────────────────────────────────────
# LOCAL DEV (Docker container):
DATABASE_URL=postgresql+asyncpg://postgres:xiima_pass@db:5432/xiimalab

# For local development without Docker, use port 5433:
# DATABASE_URL=postgresql+asyncpg://postgres:xiima_pass@localhost:5433/xiimalab

# PRODUCTION (Supabase):
# DATABASE_URL=postgresql+asyncpg://postgres:[SUPABASE_PASSWORD]@[SUPABASE_HOST]:5432/[DB_NAME]

# PostgreSQL credentials
POSTGRES_PASSWORD=xiima_pass

# ─────────────────────────────────────────────
# 🔴 REDIS — Cache & Pub/Sub
# ─────────────────────────────────────────────
# LOCAL (Docker):
REDIS_URL=redis://redis:6379

# EXTERNAL:
# REDIS_URL=redis://:password@host:6379/0

# ─────────────────────────────────────────────
# 🔴 API BACKEND — FastAPI Configuration
# ─────────────────────────────────────────────
# Frontend can reach FastAPI at this URL (server-side fetch)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal name resolution within Docker networks (used by services)
INTERNAL_API_URL=http://api:8000

# FastAPI server settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ─────────────────────────────────────────────
# 🔴 FRONTEND — Next.js Configuration
# ─────────────────────────────────────────────
# Frontend port (inside container)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Service URLs available to frontend
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# ─────────────────────────────────────────────
# 🔴 AI & LLM SERVICES
# ─────────────────────────────────────────────
# Anthropic Claude API Key (REQUIRED for /analyze/hackathon endpoint)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Fallback AI provider (optional)
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# ─────────────────────────────────────────────
# 🔴 BLOCKCHAIN — Stellar Network Configuration
# ─────────────────────────────────────────────
# Network: "testnet" or "mainnet"
STELLAR_NETWORK=testnet

# Horizon Server URL (auto-detected based on STELLAR_NETWORK, optional override)
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Platform's secret key (the account that creates & releases escrows)
# Generate new account at: https://laboratory.stellar.org/#account-creator?network=test
# ⚠️  NEVER SHARE — protect like a bank password
STELLAR_SECRET_KEY=S...YOUR_SECRET_KEY_HERE

# Payout Oracle Hot Wallet Secret (CRITICAL — used by payout-oracle service only)
# This is the account that holds XLM reserves for payouts
# ⚠️  CRITICAL SECURITY — stored only in payout-oracle container
STELLAR_PLATFORM_SECRET=S...YOUR_HOT_WALLET_SECRET

# Platform's public key (reference only, not sensitive)
STELLAR_PUBLIC_KEY=G...YOUR_PUBLIC_KEY

# Escrow Configuration
ESCROW_TIMEOUT_DAYS=180
AURA_IMAGES_MILESTONE=10

# ─────────────────────────────────────────────
# 🔴 SUPABASE — Real-time & Authentication Backend
# ─────────────────────────────────────────────
# Dashboard → Settings → API → URLs and Keys
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=eyJhbGc...YOUR_ANON_KEY

# Frontend-safe Supabase keys (can be public)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...YOUR_ANON_KEY

# Server-only Service Role Key (NEVER expose to frontend)
# Used by payout-oracle for Realtime subscriptions
SUPABASE_SERVICE_KEY=eyJhbGc...YOUR_SERVICE_ROLE_KEY

# ─────────────────────────────────────────────
# 🟡 SCRAPERS & DATA PROCESSING
# ─────────────────────────────────────────────
# Devfolio MCP Integration
# https://devfolio.co → Account Settings → Beta → MCP → Generate API Key
DEVFOLIO_MCP_API_KEY=YOUR_DEVFOLIO_MCP_KEY_HERE
DEVFOLIO_INTERVAL_MINUTES=15

# Scraper Configuration
SCRAPER_INTERVAL_MINUTES=30

# DoraHacks Scraper IDs (optional, for backup scraping)
DORAHACKS_SCRAPER_INTERVAL_HOURS=6

# Devpost Scraper Configuration
DEVPOST_SCRAPER_INTERVAL_HOURS=12

# ─────────────────────────────────────────────
# 🟡 THIRD-PARTY INTEGRATIONS
# ─────────────────────────────────────────────
# RedimensionAI Microservice (AURA — image resizing engine)
REDIMENSION_AI_URL=http://localhost:8001

# Hotmart E-learning Platform (Proof of Skill purchases)
HOTMART_WEBHOOK_SECRET=YOUR_HOTMART_WEBHOOK_SECRET

# ─────────────────────────────────────────────
# 🟡 AGENT & ML CONFIGURATION
# ─────────────────────────────────────────────
# Agent Crew Parameters
AGENT_TOP_MATCHES=3
AGENT_MIN_SCORE=40
AGENT_INSIGHT_TTL_DAYS=14

# ML Embedding Model
ML_MODEL=all-MiniLM-L6-v2

# Monitor & Validator Configuration
MONITOR_INTERVAL=300
VALIDATOR_INTERVAL_SEC=60
STAKING_MONITOR_INTERVAL_SEC=60

# Payout Oracle Settings
MAX_RETRIES=3
POLL_INTERVAL_SEC=30

# ─────────────────────────────────────────────
# 🟡 DOCKER & DEPLOYMENT
# ─────────────────────────────────────────────
# Production Domain (used by Caddy reverse proxy)
DOMAIN_NAME=api.xiimalab.local

# Container Environment
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ─────────────────────────────────────────────
# 🔵 EXPERIMENTAL & FUTURE
# ─────────────────────────────────────────────
# Avalanche (Future support)
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Versioning & Feature Flags
FEATURE_FLAG_WALLET_CONNECT=false
APP_VERSION=0.1.0
