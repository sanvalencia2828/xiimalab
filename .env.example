# ─────────────────────────────────────────────
# Xiimalab — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# Redis (no auth needed for local dev)
# REDIS_PASSWORD=

# Scraper
SCRAPER_INTERVAL_MINUTES=30

# Next.js Auth
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# API internal URL (used by Next.js server-side fetch)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─────────────────────────────────────────────
# Stellar Blockchain — Proof of Skill
# ─────────────────────────────────────────────
# Red: "testnet" o "mainnet"
STELLAR_NETWORK=testnet

# Clave secreta de la cuenta de la PLATAFORMA (la que crea y libera escrows)
# Genera una nueva en: https://laboratory.stellar.org/#account-creator?network=test
# ⚠️  NUNCA compartas ni subas esta clave al repositorio
STELLAR_SECRET_KEY=

# Clave pública de la plataforma (para referencia, no es secreta)
STELLAR_PUBLIC_KEY=

# Días de gracia antes de reembolso automático al estudiante
ESCROW_TIMEOUT_DAYS=180

# Imágenes AURA requeridas para liberar el staking
AURA_IMAGES_MILESTONE=10

# ─────────────────────────────────────────────
# Hotmart Integration — Webhook
# ─────────────────────────────────────────────
# Secreto para verificar la firma HMAC de los webhooks de Hotmart
# Configúralo en: Panel Hotmart > Ferramentas > Webhook
HOTMART_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# AI (Anthropic)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Avalanche (futuro)
# ─────────────────────────────────────────────
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
